          "type": "liquid",
          "settings": {
            "liquid": "<!-- ================================================================\n  Bloc \"Forte demande / Stocks limités\" — indicateur d'urgence\n  100% autonome : à coller dans la description produit\n  (éditeur Shopify > fiche produit > afficher le HTML </>)\n  ou dans un bloc \"HTML personnalisé\" / \"Liquid\" de la fiche produit.\n================================================================= -->\n<style>\n  .pstock {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    margin: 0;\n    padding: 0;\n    font-family: inherit;\n  }\n  /* Point qui pulse */\n  .pstock__dot {\n    position: relative;\n    flex: 0 0 12px;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    border: 2px solid #ff4d1f;\n  }\n  .pstock__dot::after {\n    content: \"\";\n    position: absolute;\n    inset: 2px;\n    border-radius: 50%;\n    background: #ff4d1f;\n    animation: pstock-pulse 1.4s ease-in-out infinite;\n  }\n  @keyframes pstock-pulse {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50%      { opacity: .45; transform: scale(.75); }\n  }\n  @media (prefers-reduced-motion: reduce) {\n    .pstock__dot::after { animation: none; }\n  }\n  .pstock__label {\n    font-size: 15px;\n    color: #ff4d1f;\n  }\n  .pstock__badge {\n    background: #ffe3da;\n    color: #ff4d1f;\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 0.05em;\n    text-transform: uppercase;\n    padding: 5px 10px;\n    border-radius: 6px;\n    white-space: nowrap;\n  }\n</style>\n\n<div class=\"pstock\">\n  <span class=\"pstock__dot\" aria-hidden=\"true\"></span>\n  <span class=\"pstock__label\">Forte demande</span>\n  <span class=\"pstock__badge\">Stocks limités</span>\n</div>"
