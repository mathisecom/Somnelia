        "liquid_Vmj9e9": {
          "type": "liquid",
          "settings": {
            "liquid": "<!-- ================================================================\n  Bloc \"Bénéfices produit\" — 2 colonnes PC / 1 colonne mobile\n  100% autonome : à coller tel quel dans la description produit\n  (éditeur Shopify > fiche produit > afficher le HTML </>)\n  ou dans un bloc \"HTML personnalisé\" / \"Liquid\" de la fiche produit.\n================================================================= -->\n<style>\n  .pbenef {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px 32px;\n    margin: 16px 0;\n    font-family: inherit;\n    color: #1d2153;\n  }\n  .pbenef__item {\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n  }\n  .pbenef__icon {\n    flex: 0 0 24px;\n    width: 24px;\n    height: 24px;\n    color: #1d2153;\n  }\n  .pbenef__icon svg { width: 100%; height: 100%; display: block; }\n  .pbenef__text {\n    margin: 0;\n    font-size: 13px;\n    line-height: 1.4;\n  }\n  .pbenef__text strong { font-weight: 700; }\n  @media (max-width: 640px) {\n    .pbenef { grid-template-columns: 1fr; gap: 14px; }\n  }\n</style>\n<div class=\"pbenef\">\n  <!-- Bénéfice 1 : nuque alignée / réveil sans tensions\n       Icône : personne allongée de profil, tête posée à niveau -->\n  <div class=\"pbenef__item\">\n    <span class=\"pbenef__icon\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <circle cx=\"5.5\" cy=\"9.5\" r=\"2.3\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n        <path d=\"M8.5 10.5H20\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n        <path d=\"M3 15.5H21\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n        <path d=\"M6 15.5V18.5M18 15.5V18.5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n      </svg>\n    </span>\n    <p class=\"pbenef__text\"><strong>Nuque et cervicales à niveau</strong> - réveillez-vous sans raideurs</p>\n  </div>\n  <!-- Bénéfice 2 : toutes positions de sommeil\n       Icône : flèches de rotation autour d'un point (changement de position) -->\n  <div class=\"pbenef__item\">\n    <span class=\"pbenef__icon\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <path d=\"M19.5 12A7.5 7.5 0 1 1 12 4.5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n        <path d=\"M12 2L15 4.5L12 7\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        <circle cx=\"12\" cy=\"12\" r=\"1.6\" fill=\"currentColor\"/>\n      </svg>\n    </span>\n    <p class=\"pbenef__text\"><strong>Pensé pour chaque position</strong> - il vous suit quand vous bougez</p>\n  </div>\n  <!-- Bénéfice 3 : mousse qui reprend sa forme\n       Icône : coussin avec flèche de rebond vers le haut -->\n  <div class=\"pbenef__item\">\n    <span class=\"pbenef__icon\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"3.5\" y=\"13\" width=\"17\" height=\"7\" rx=\"2.5\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n        <path d=\"M12 10.5V3.5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\"/>\n        <path d=\"M8.8 6.5L12 3.2L15.2 6.5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </span>\n    <p class=\"pbenef__text\"><strong>Une mousse qui ne s'affaisse pas</strong> - même confort nuit après nuit</p>\n  </div>\n  <!-- Bénéfice 4 : place pour les bras / circulation\n       Icône : coussin avec flèches d'espace vers l'extérieur -->\n  <div class=\"pbenef__item\">\n    <span class=\"pbenef__icon\" aria-hidden=\"true\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"7\" y=\"8.5\" width=\"10\" height=\"7\" rx=\"3\" stroke=\"currentColor\" stroke-width=\"1.8\"/>\n        <path d=\"M4.5 12H1.8M1.8 12L3.6 10.2M1.8 12L3.6 13.8\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        <path d=\"M19.5 12H22.2M22.2 12L20.4 10.2M22.2 12L20.4 13.8\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </span>\n    <p class=\"pbenef__text\"><strong>De l'espace pour vos bras</strong> - circulation libre, zéro fourmillements</p>\n  </div>\n</div>"
          }
