        "liquid_8NbH9H": {
          "type": "liquid",
          "settings": {
            "liquid": "<style>\n  .somnelia-reassurance {\n    width: 100%;\n    padding: 22px 12px;\n    background: #F4F4F1;\n    box-sizing: border-box;\n  }\n\n  .somnelia-reassurance__grid {\n    max-width: 850px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    align-items: start;\n    gap: 24px;\n  }\n\n  .somnelia-reassurance__item {\n    position: relative;\n    text-align: center;\n    color: #0e1a2b;\n  }\n\n  .somnelia-reassurance__icon {\n    width: 36px;\n    height: 36px;\n    margin: 0 auto 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .somnelia-reassurance__icon svg {\n    width: 100%;\n    height: 100%;\n    fill: none;\n    stroke: currentColor;\n    stroke-width: 1.8;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .somnelia-reassurance__title {\n    margin: 0;\n    font-family: Outfit, Arial, sans-serif;\n    font-size: 14px;\n    font-weight: 650;\n    line-height: 1.2;\n  }\n\n  .somnelia-reassurance__info {\n    position: relative;\n    width: 16px;\n    height: 16px;\n    margin: 9px auto 0;\n    border: 1.4px solid #0e1a2b;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-family: Arial, sans-serif;\n    font-size: 10px;\n    font-weight: 700;\n    cursor: help;\n  }\n\n  .somnelia-reassurance__tooltip {\n    position: absolute;\n    z-index: 20;\n    left: 50%;\n    bottom: calc(100% + 10px);\n    width: 195px;\n    padding: 9px 11px;\n    border-radius: 8px;\n    background: #0e1a2b;\n    color: #ffffff;\n    font-family: Outfit, Arial, sans-serif;\n    font-size: 11px;\n    font-weight: 400;\n    line-height: 1.35;\n    text-align: center;\n    box-shadow: 0 7px 22px rgba(14, 26, 43, 0.16);\n    opacity: 0;\n    visibility: hidden;\n    pointer-events: none;\n    transform: translate(-50%, 5px);\n    transition: opacity 0.2s ease, transform 0.2s ease;\n  }\n\n  .somnelia-reassurance__tooltip::after {\n    content: \"\";\n    position: absolute;\n    left: 50%;\n    top: 100%;\n    transform: translateX(-50%);\n    border: 6px solid transparent;\n    border-top-color: #0e1a2b;\n  }\n\n  .somnelia-reassurance__info:hover .somnelia-reassurance__tooltip,\n  .somnelia-reassurance__info:focus .somnelia-reassurance__tooltip {\n    opacity: 1;\n    visibility: visible;\n    transform: translate(-50%, 0);\n  }\n\n  @media screen and (max-width: 600px) {\n    .somnelia-reassurance {\n      padding: 18px 6px;\n    }\n\n    .somnelia-reassurance__grid {\n      gap: 8px;\n    }\n\n    .somnelia-reassurance__icon {\n      width: 29px;\n      height: 29px;\n      margin-bottom: 6px;\n    }\n\n    .somnelia-reassurance__title {\n      font-size: 11px;\n      line-height: 1.18;\n    }\n\n    .somnelia-reassurance__info {\n      width: 15px;\n      height: 15px;\n      margin-top: 8px;\n      font-size: 9px;\n    }\n\n    .somnelia-reassurance__tooltip {\n      width: 145px;\n      padding: 8px 9px;\n      font-size: 10px;\n    }\n  }\n</style>\n\n<section class=\"somnelia-reassurance\" aria-label=\"Nos engagements\">\n  <div class=\"somnelia-reassurance__grid\">\n\n    <div class=\"somnelia-reassurance__item\">\n      <div class=\"somnelia-reassurance__icon\">\n        <svg viewBox=\"0 0 48 48\" aria-hidden=\"true\">\n          <path d=\"M35.5 30.5A15.5 15.5 0 1 1 18 9.2a13.2 13.2 0 0 0 17.5 21.3Z\"/>\n          <path d=\"M34.5 8.5v5\"/>\n          <path d=\"M32 11h5\"/>\n          <path d=\"M40 17v3\"/>\n          <path d=\"M38.5 18.5h3\"/>\n        </svg>\n      </div>\n\n      <p class=\"somnelia-reassurance__title\">\n        30 nuits<br>d'essai\n      </p>\n\n      <div class=\"somnelia-reassurance__info\" tabindex=\"0\" aria-label=\"Informations sur les 30 nuits d'essai\">\n        i\n        <span class=\"somnelia-reassurance__tooltip\">\n          Testez votre oreiller Somnelia pendant 30 nuits en toute tranquillité.\n        </span>\n      </div>\n    </div>\n\n    <div class=\"somnelia-reassurance__item\">\n      <div class=\"somnelia-reassurance__icon\">\n        <svg viewBox=\"0 0 48 48\" aria-hidden=\"true\">\n          <path d=\"M5 13h24v21H5Z\"/>\n          <path d=\"M29 20h7l7 7v7H29Z\"/>\n          <path d=\"M9 9v4\"/>\n          <path d=\"M4 9h5\"/>\n          <path d=\"M3 18H0\"/>\n          <path d=\"M8 23H3\"/>\n          <circle cx=\"13\" cy=\"35\" r=\"4\"/>\n          <circle cx=\"36\" cy=\"35\" r=\"4\"/>\n        </svg>\n      </div>\n\n      <p class=\"somnelia-reassurance__title\">\n        Livraison et<br>retour offerts\n      </p>\n\n      <div class=\"somnelia-reassurance__info\" tabindex=\"0\" aria-label=\"Informations sur la livraison\">\n        i\n        <span class=\"somnelia-reassurance__tooltip\">\n          Profitez de la livraison et du retour offerts selon les conditions de notre boutique.\n        </span>\n      </div>\n    </div>\n\n    <div class=\"somnelia-reassurance__item\">\n      <div class=\"somnelia-reassurance__icon\">\n        <svg viewBox=\"0 0 48 48\" aria-hidden=\"true\">\n          <path d=\"M12 24a12 12 0 0 1 24 0\"/>\n          <path d=\"M12 24v9a4 4 0 0 0 4 4h2V24h-2a4 4 0 0 0-4 4\"/>\n          <path d=\"M36 24v9a4 4 0 0 1-4 4h-2V24h2a4 4 0 0 1 4 4\"/>\n          <path d=\"M30 37c0 3-3 5-7 5\"/>\n        </svg>\n      </div>\n\n      <p class=\"somnelia-reassurance__title\">\n        Une équipe à<br>votre écoute\n      </p>\n\n      <div class=\"somnelia-reassurance__info\" tabindex=\"0\" aria-label=\"Informations sur le service client\">\n        i\n        <span class=\"somnelia-reassurance__tooltip\">\n          Notre équipe est disponible pour vous accompagner avant et après votre commande.\n        </span>\n      </div>\n    </div>\n\n  </div>\n</section>"
