r formattedDate = shipDate.toLocaleDateString('fr-FR', options);\n\n      var shippingDateElement = document.getElementById('shipping-date');\n      if (shippingDateElement) {\n        shippingDateElement.textContent = formattedDate;\n      }\n    });\n  </script>\n\n  <div class=\"custom-shipping-container\">\n    <div class=\"custom-shipping-item\">\n      <svg class=\"green-circle\" width=\"12\" height=\"13\" viewBox=\"0 0 12 13\" fill=\"none\" aria-hidden=\"true\">\n        <circle cx=\"6\" cy=\"6.5\" r=\"6\" fill=\"#137333\"></circle>\n      </svg>\n\n      <div class=\"text-block-shipping\">\n        Expédié le <span id=\"shipping-date\" class=\"shipping-date\">dim. 12 juillet</span>\n      </div>\n    </div>\n\n    <div class=\"custom-shipping-item\">\n      <svg class=\"custom-truck-icon\" viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n        <path d=\"M3 7h11v10H3V7Z\" stroke=\"#000\" stroke-width=\"1.8\" stroke-linejoin=\"round\"></path>\n        <path d=\"M14 10h4l3 3v4h-7v-7Z\" stroke=\"#000\" stroke-width=\"1.8\" stroke-linejoin=\"round\"></path>\n        <circle cx=\"7\" cy=\"18\" r=\"2\" stroke=\"#000\" stroke-width=\"1.8\"></circle>\n        <circle cx=\"17\" cy=\"18\" r=\"2\" stroke=\"#000\" stroke-width=\"1.8\"></circle>\n      </svg>\n\n      <div class=\"text-block-shipping\">\n        <span class=\"free-shipping\">Livraison Offerte</span> en France\n      </div>\n    </div>\n  </div>\n</div>\n            </div></div>\n            </div></div>"
