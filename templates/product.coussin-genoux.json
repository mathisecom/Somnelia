        "liquid_GaGCCD": {
          "type": "liquid",
          "settings": {
            "liquid": "<div class=\"product-info__block-item\" data-block-id=\"liquid_UFHp6A\" data-block-type=\"liquid\"><div class=\"product-info__liquid\">\n              <div class=\"product-info__block-item\" data-block-id=\"liquid_gx7Xka\" data-block-type=\"liquid\"><div class=\"product-info__liquid\">\n              <style>\n  .dod-firmness-meter {\n    width: 100%;\n    max-width: 420px;\n    margin: 12px 0 16px;\n    font-family: inherit;\n\n    /* Modifications rapides */\n    --bar-bg: #eef8f2;\n    --active-bg: #b8e4cc;\n    --text-muted: #a5a3b8;\n    --text-active: #007a4d;\n    --radius: 999px;\n  }\n\n  .dod-firmness-meter__bar {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    background: var(--bar-bg);\n    border-radius: var(--radius);\n    overflow: hidden;\n    height: 34px;\n  }\n\n  .dod-firmness-meter__item {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    text-transform: uppercase;\n    color: #b8c9bf;\n  }\n\n  .dod-firmness-meter__item.is-active {\n    background: var(--active-bg);\n    color: var(--text-active);\n  }\n\n  .dod-firmness-meter__labels {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    margin-top: 7px;\n    text-align: center;\n  }\n\n  .dod-firmness-meter__label {\n    font-size: 12px;\n    line-height: 1.2;\n    color: var(--text-muted);\n  }\n\n  .dod-firmness-meter__label.is-active {\n    color: var(--text-active);\n    font-weight: 600;\n  }\n\n  @media screen and (max-width: 749px) {\n    .dod-firmness-meter {\n      max-width: 100%;\n      margin: 10px 0 14px;\n    }\n\n    .dod-firmness-meter__bar {\n      height: 32px;\n    }\n\n    .dod-firmness-meter__item {\n      font-size: 10px;\n    }\n\n    .dod-firmness-meter__label {\n      font-size: 11px;\n    }\n  }\n</style>\n\n<div class=\"dod-firmness-meter\">\n  <div class=\"dod-firmness-meter__bar\">\n    <div class=\"dod-firmness-meter__item\">\n      Moelleux\n    </div>\n\n    <div class=\"dod-firmness-meter__item is-active\">\n      Équilibré\n    </div>\n\n    <div class=\"dod-firmness-meter__item\">\n      Ferme\n    </div>\n  </div>\n\n  <div class=\"dod-firmness-meter__labels\">\n    <div class=\"dod-firmness-meter__label\">\n      Confort doux\n    </div>\n\n    <div class=\"dod-firmness-meter__label is-active\">\n      Soutien équilibré\n    </div>\n\n    <div class=\"dod-firmness-meter__label\">\n      Soutien ferme\n    </div>\n  </div>\n</div>\n            </div></div>\n            </div></div>"
