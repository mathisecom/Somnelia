{%- comment -%}
  Section : Bannière Promo + Cartes Deals (style "Summer Deals")
  - 100% personnalisable via l'éditeur de thème
  - Taille de TOUTES les typographies réglable (PC + mobile)
  - Police Epilogue (avec repli sur la police du thème)
  - Responsive PC / Mobile
  Installation : Boutique en ligne > Thèmes > Modifier le code >
  Sections > Ajouter une nouvelle section > "promo-deals" > coller ce code
{%- endcomment -%}

{%- style -%}
  #Promo-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.section_bg }};
    font-family: 'Epilogue', var(--font-body-family, sans-serif);
  }
  #Promo-{{ section.id }} .promo__wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ---------- HERO ---------- */
  #Promo-{{ section.id }} .promo__hero {
    display: grid;
    grid-template-columns: {{ section.settings.text_ratio }}fr {{ 100 | minus: section.settings.text_ratio }}fr;
    border-radius: {{ section.settings.radius }}px;
    overflow: hidden;
    background: {{ section.settings.hero_bg }};
  }
  #Promo-{{ section.id }} .promo__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 48px 40px;
    gap: 22px;
  }
  #Promo-{{ section.id }} .promo__trust {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
    font-size: {{ section.settings.trust_size }}px;
    color: {{ section.settings.text_color }};
  }
  #Promo-{{ section.id }} .promo__stars {
    display: flex;
    gap: 3px;
  }
  #Promo-{{ section.id }} .promo__star {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: {{ section.settings.star_bg }};
  }
  #Promo-{{ section.id }} .promo__star svg { width: 14px; height: 14px; fill: #fff; }
  #Promo-{{ section.id }} .promo__star--half {
    background: linear-gradient(90deg, {{ section.settings.star_bg }} 50%, #d5d5d5 50%);
  }
  #Promo-{{ section.id }} .promo__trust strong { font-weight: 700; }
  #Promo-{{ section.id }} .promo__trust-logo {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 700;
  }
  #Promo-{{ section.id }} .promo__trust-logo svg { width: 16px; height: 16px; fill: {{ section.settings.star_bg }}; }

  #Promo-{{ section.id }} .promo__title {
    font-family: 'Epilogue', var(--font-heading-family, sans-serif);
    font-size: {{ section.settings.title_size }}px;
    line-height: 1.05;
    margin: 0;
    color: {{ section.settings.text_color }};
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }
  #Promo-{{ section.id }} .promo__title-part1 { font-weight: 700; }
  #Promo-{{ section.id }} .promo__title-part2 { font-style: italic; font-weight: 500; }
  #Promo-{{ section.id }} .promo__title-flower {
    width: 0.9em;
    height: 0.9em;
    flex: none;
  }
  #Promo-{{ section.id }} .promo__subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    line-height: 1.5;
    max-width: 560px;
    margin: 0;
    color: {{ section.settings.text_color }};
  }
  #Promo-{{ section.id }} .promo__btn {
    display: inline-block;
    background: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    font-size: {{ section.settings.btn_size }}px;
    font-weight: 600;
    padding: 16px 44px;
    border-radius: 999px;
    text-decoration: none;
    transition: transform .2s ease, filter .2s ease;
  }
  #Promo-{{ section.id }} .promo__btn:hover { filter: brightness(0.92); transform: translateY(-1px); }

  #Promo-{{ section.id }} .promo__media {
    position: relative;
    min-height: 420px;
  }
  #Promo-{{ section.id }} .promo__media img,
  #Promo-{{ section.id }} .promo__media .promo__media-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  #Promo-{{ section.id }} .promo__media-placeholder { background: #dfe4ea; }

  /* ---------- CARTES DEALS ---------- */
  #Promo-{{ section.id }} .promo__cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
    margin-top: 28px;
  }
  #Promo-{{ section.id }} .promo-card {
    position: relative;
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 28px 64px 28px 28px;
    border-radius: {{ section.settings.radius }}px;
    text-decoration: none;
    overflow: hidden;
    transition: transform .2s ease, box-shadow .2s ease;
  }
  #Promo-{{ section.id }} .promo-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(0,0,0,.08);
  }
  #Promo-{{ section.id }} .promo-card__visual {
    position: relative;
    flex: none;
    width: 150px;
    height: 110px;
  }
  #Promo-{{ section.id }} .promo-card__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #Promo-{{ section.id }} .promo-card__badge {
    position: absolute;
    right: -28px;
    top: 50%;
    transform: translateY(-50%);
    width: 84px;
    height: 84px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: {{ section.settings.text_color }};
  }
  #Promo-{{ section.id }} .promo-card__badge svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  #Promo-{{ section.id }} .promo-card__badge-text {
    position: relative;
    font-family: 'Epilogue', var(--font-heading-family, sans-serif);
    line-height: 1.05;
  }
  #Promo-{{ section.id }} .promo-card__badge-text .line1 {
    font-size: {{ section.settings.badge_size1 }}px;
    font-style: italic;
    font-weight: 700;
    display: block;
  }
  #Promo-{{ section.id }} .promo-card__badge-text .line2 {
    font-size: {{ section.settings.badge_size2 }}px;
    font-style: italic;
    letter-spacing: .05em;
    display: block;
  }
  #Promo-{{ section.id }} .promo-card__texts { color: {{ section.settings.text_color }}; }
  #Promo-{{ section.id }} .promo-card__title {
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: 700;
    margin: 0 0 8px;
    display: block;
  }
  #Promo-{{ section.id }} .promo-card__desc {
    font-size: {{ section.settings.card_desc_size }}px;
    line-height: 1.5;
    margin: 0;
  }
  #Promo-{{ section.id }} .promo-card__arrow {
    position: absolute;
    right: 22px;
    top: 50%;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: {{ section.settings.btn_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    flex: none;
  }
  #Promo-{{ section.id }} .promo-card__arrow svg { width: 14px; height: 14px; fill: {{ section.settings.btn_text_color }}; }

  /* ---------- AVANTAGES / REASSURANCE ---------- */
  #Promo-{{ section.id }} .promo__benefits {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px 48px;
    margin-top: 32px;
    color: {{ section.settings.text_color }};
  }
  #Promo-{{ section.id }} .promo__benefit {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: {{ section.settings.benefit_size }}px;
  }
  #Promo-{{ section.id }} .promo__benefit-icon {
    width: 26px;
    height: 26px;
    flex: none;
  }
  #Promo-{{ section.id }} .promo__benefit-icon img { width: 100%; height: 100%; object-fit: contain; }
  #Promo-{{ section.id }} .promo__benefit-icon svg { width: 100%; height: 100%; fill: none; stroke: currentColor; stroke-width: 1.5; }

  /* ---------- MOBILE ---------- */
  @media screen and (max-width: 749px) {
    #Promo-{{ section.id }} .promo__hero {
      grid-template-columns: 1fr;
    }
    #Promo-{{ section.id }} .promo__media {
      order: -1;
      min-height: 220px;
    }
    #Promo-{{ section.id }} .promo__content {
      padding: 32px 20px 36px;
      gap: 18px;
    }
    {%- if section.settings.trust_below_mobile -%}
    #Promo-{{ section.id }} .promo__trust { order: 5; }
    {%- endif -%}
    #Promo-{{ section.id }} .promo__trust { font-size: {{ section.settings.trust_size_mobile }}px; }
    #Promo-{{ section.id }} .promo__title { font-size: {{ section.settings.title_size_mobile }}px; }
    #Promo-{{ section.id }} .promo__subtitle { font-size: {{ section.settings.subtitle_size_mobile }}px; }
    #Promo-{{ section.id }} .promo__btn { font-size: {{ section.settings.btn_size_mobile }}px; }
    #Promo-{{ section.id }} .promo__cards { grid-template-columns: repeat(2, 1fr); gap: 14px; }
    #Promo-{{ section.id }} .promo-card {
      flex-direction: column;
      align-items: flex-start;
      padding: 20px 18px 52px;
      gap: 14px;
    }
    #Promo-{{ section.id }} .promo-card__visual { width: 120px; height: 90px; }
    #Promo-{{ section.id }} .promo-card__badge { width: 68px; height: 68px; right: -34px; }
    #Promo-{{ section.id }} .promo-card__badge-text .line1 { font-size: {{ section.settings.badge_size1 | times: 0.8 | round }}px; }
    #Promo-{{ section.id }} .promo-card__badge-text .line2 { font-size: {{ section.settings.badge_size2 | times: 0.9 | round }}px; }
    #Promo-{{ section.id }} .promo-card__title { font-size: {{ section.settings.card_title_size_mobile }}px; }
    #Promo-{{ section.id }} .promo-card__desc {
      display: {% if section.settings.hide_desc_mobile %}none{% else %}block{% endif %};
      font-size: {{ section.settings.card_desc_size_mobile }}px;
    }
    #Promo-{{ section.id }} .promo-card__arrow { left: 18px; right: auto; top: auto; bottom: 14px; transform: none; width: 30px; height: 30px; }
    #Promo-{{ section.id }} .promo__benefits { gap: 14px 28px; }
    #Promo-{{ section.id }} .promo__benefit { font-size: {{ section.settings.benefit_size_mobile }}px; }
  }
  @media screen and (max-width: 420px) {
    #Promo-{{ section.id }} .promo__cards { grid-template-columns: 1fr 1fr; }
  }
{%- endstyle -%}

{%- comment -%} Chargement de secours de la police Epilogue (ne fait rien si le thème la charge déjà) {%- endcomment -%}
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,400;0,500;0,600;0,700;1,500;1,700&display=swap" rel="stylesheet">

{%- capture flower_svg -%}
  <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <g fill="FLOWER_COLOR">
      <circle cx="50" cy="22" r="20"/>
      <circle cx="76" cy="38" r="20"/>
      <circle cx="68" cy="68" r="20"/>
      <circle cx="32" cy="68" r="20"/>
      <circle cx="24" cy="38" r="20"/>
      <circle cx="50" cy="48" r="22"/>
    </g>
  </svg>
{%- endcapture -%}

<div id="Promo-{{ section.id }}">
  <div class="promo__wrapper">

    {%- comment -%} ============ HERO ============ {%- endcomment -%}
    <div class="promo__hero">
      <div class="promo__content">

        {%- if section.settings.show_trust -%}
          <div class="promo__trust">
            <span class="promo__stars" aria-hidden="true">
              {%- assign full_stars = section.settings.rating | floor -%}
              {%- for i in (1..5) -%}
                {%- if i <= full_stars -%}
                  <span class="promo__star"><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7-6.2-3.7L5.8 21l1.6-7L2 9.2l7.1-.6z"/></svg></span>
                {%- else -%}
                  <span class="promo__star promo__star--half"><svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7-6.2-3.7L5.8 21l1.6-7L2 9.2l7.1-.6z"/></svg></span>
                {%- endif -%}
              {%- endfor -%}
            </span>
            <span><strong>{{ section.settings.review_count }}</strong> {{ section.settings.review_text }}</span>
            <span class="promo__trust-logo">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.9 6.6 7.1.6-5.4 4.7 1.6 7-6.2-3.7L5.8 21l1.6-7L2 9.2l7.1-.6z"/></svg>
              {{ section.settings.trust_name }}
            </span>
          </div>
        {%- endif -%}

        <h2 class="promo__title">
          <span class="promo__title-part1">{{ section.settings.title_part1 }}</span>
          {%- if section.settings.show_flower -%}
            <span class="promo__title-flower">{{ flower_svg | replace: 'FLOWER_COLOR', section.settings.flower_color }}</span>
          {%- endif -%}
          <span class="promo__title-part2">{{ section.settings.title_part2 }}</span>
        </h2>

        {%- if section.settings.subtitle != blank -%}
          <p class="promo__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        {%- if section.settings.btn_label != blank -%}
          <a href="{{ section.settings.btn_link | default: '#' }}" class="promo__btn">{{ section.settings.btn_label }}</a>
        {%- endif -%}
      </div>

      <div class="promo__media">
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | image_url: width: 1600 | image_tag: loading: 'lazy', alt: section.settings.hero_image.alt | default: section.settings.title_part1 }}
        {%- else -%}
          <div class="promo__media-placeholder">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ============ CARTES DEALS (blocs) ============ {%- endcomment -%}
    {%- assign deal_blocks = section.blocks | where: 'type', 'deal' -%}
    {%- if deal_blocks.size > 0 -%}
      <div class="promo__cards">
        {%- for block in deal_blocks -%}
          <a href="{{ block.settings.link | default: '#' }}"
             class="promo-card"
             style="background: {{ block.settings.bg }};"
             {{ block.shopify_attributes }}>
            <span class="promo-card__visual">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag }}
              {%- endif -%}
              {%- if block.settings.badge_line1 != blank -%}
                <span class="promo-card__badge">
                  {{ flower_svg | replace: 'FLOWER_COLOR', block.settings.badge_color }}
                  <span class="promo-card__badge-text">
                    <span class="line1">{{ block.settings.badge_line1 }}</span>
                    <span class="line2">{{ block.settings.badge_line2 }}</span>
                  </span>
                </span>
              {%- endif -%}
            </span>
            <span class="promo-card__texts">
              <span class="promo-card__title">{{ block.settings.title }}</span>
              {%- if block.settings.desc != blank -%}
                <p class="promo-card__desc">{{ block.settings.desc }}</p>
              {%- endif -%}
            </span>
            <span class="promo-card__arrow" aria-hidden="true">
              <svg viewBox="0 0 24 24"><path d="M8.6 3.4L7.2 4.8 14.4 12l-7.2 7.2 1.4 1.4L17.2 12z"/></svg>
            </span>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ============ AVANTAGES (blocs) ============ {%- endcomment -%}
    {%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
    {%- if benefit_blocks.size > 0 -%}
      <div class="promo__benefits">
        {%- for block in benefit_blocks -%}
          <div class="promo__benefit" {{ block.shopify_attributes }}>
            <span class="promo__benefit-icon">
              {%- if block.settings.icon_image != blank -%}
                {{ block.settings.icon_image | image_url: width: 60 | image_tag: loading: 'lazy', alt: '' }}
              {%- else -%}
                {%- case block.settings.icon -%}
                  {%- when 'medal' -%}
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="9" r="6"/><path d="M8.5 14L7 22l5-3 5 3-1.5-8"/></svg>
                  {%- when 'pillow' -%}
                    <svg viewBox="0 0 24 24"><path d="M3 7c3-2 15-2 18 0 1 3 1 7 0 10-3 2-15 2-18 0-1-3-1-7 0-10z"/></svg>
                  {%- when 'delivery' -%}
                    <svg viewBox="0 0 24 24"><rect x="2" y="6" width="13" height="10" rx="1"/><path d="M15 9h4l3 3v4h-7"/><circle cx="7" cy="18" r="1.8"/><circle cx="18" cy="18" r="1.8"/></svg>
                  {%- when 'shield' -%}
                    <svg viewBox="0 0 24 24"><path d="M12 2l8 3v6c0 5-3.5 9-8 11-4.5-2-8-6-8-11V5z"/><path d="M8.5 12l2.5 2.5L16 9.5"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l2.5 2.5L16 9.5"/></svg>
                {%- endcase -%}
              {%- endif -%}
            </span>
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Bannière Promo Deals",
  "tag": "section",
  "class": "section-promo-deals",
  "settings": [
    { "type": "header", "content": "Mise en page" },
    { "type": "range", "id": "max_width", "min": 1000, "max": 1800, "step": 20, "unit": "px", "label": "Largeur maximale", "default": 1600 },
    { "type": "range", "id": "text_ratio", "min": 30, "max": 60, "step": 5, "unit": "%", "label": "Largeur zone texte (PC)", "default": 40 },
    { "type": "range", "id": "radius", "min": 0, "max": 40, "step": 2, "unit": "px", "label": "Arrondi des angles", "default": 16 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espace haut", "default": 36 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "label": "Espace bas", "default": 36 },

    { "type": "header", "content": "Couleurs" },
    { "type": "color", "id": "section_bg", "label": "Fond de la section", "default": "#F5F3EE" },
    { "type": "color", "id": "hero_bg", "label": "Fond de la bannière", "default": "#EEEBE3" },
    { "type": "color", "id": "text_color", "label": "Couleur du texte", "default": "#1a1a1a" },
    { "type": "color", "id": "btn_bg", "label": "Fond du bouton", "default": "#F97316" },
    { "type": "color", "id": "btn_text_color", "label": "Texte du bouton", "default": "#FFFFFF" },
    { "type": "color", "id": "flower_color", "label": "Couleur de la fleur du titre", "default": "#F2B72C" },

    { "type": "header", "content": "Tailles de texte — PC" },
    { "type": "range", "id": "title_size", "min": 28, "max": 80, "step": 2, "unit": "px", "label": "Titre", "default": 52 },
    { "type": "range", "id": "subtitle_size", "min": 12, "max": 26, "step": 1, "unit": "px", "label": "Sous-titre", "default": 17 },
    { "type": "range", "id": "trust_size", "min": 10, "max": 22, "step": 1, "unit": "px", "label": "Ligne d'avis (Trustpilot)", "default": 14 },
    { "type": "range", "id": "btn_size", "min": 12, "max": 26, "step": 1, "unit": "px", "label": "Bouton", "default": 17 },
    { "type": "range", "id": "card_title_size", "min": 14, "max": 32, "step": 1, "unit": "px", "label": "Titre des cartes deals", "default": 20 },
    { "type": "range", "id": "card_desc_size", "min": 11, "max": 22, "step": 1, "unit": "px", "label": "Description des cartes deals", "default": 15 },
    { "type": "range", "id": "badge_size1", "min": 12, "max": 32, "step": 1, "unit": "px", "label": "Badge fleur — ligne 1 (1+1)", "default": 20 },
    { "type": "range", "id": "badge_size2", "min": 8, "max": 18, "step": 1, "unit": "px", "label": "Badge fleur — ligne 2 (OFFERT)", "default": 10 },
    { "type": "range", "id": "benefit_size", "min": 11, "max": 22, "step": 1, "unit": "px", "label": "Avantages / réassurance", "default": 15 },

    { "type": "header", "content": "Tailles de texte — Mobile" },
    { "type": "range", "id": "title_size_mobile", "min": 20, "max": 56, "step": 2, "unit": "px", "label": "Titre", "default": 36 },
    { "type": "range", "id": "subtitle_size_mobile", "min": 11, "max": 22, "step": 1, "unit": "px", "label": "Sous-titre", "default": 15 },
    { "type": "range", "id": "trust_size_mobile", "min": 9, "max": 18, "step": 1, "unit": "px", "label": "Ligne d'avis (Trustpilot)", "default": 13 },
    { "type": "range", "id": "btn_size_mobile", "min": 12, "max": 22, "step": 1, "unit": "px", "label": "Bouton", "default": 16 },
    { "type": "range", "id": "card_title_size_mobile", "min": 12, "max": 26, "step": 1, "unit": "px", "label": "Titre des cartes deals", "default": 16 },
    { "type": "range", "id": "card_desc_size_mobile", "min": 10, "max": 18, "step": 1, "unit": "px", "label": "Description des cartes deals", "default": 13 },
    { "type": "range", "id": "benefit_size_mobile", "min": 10, "max": 18, "step": 1, "unit": "px", "label": "Avantages / réassurance", "default": 13 },

    { "type": "header", "content": "Avis clients (Trustpilot)" },
    { "type": "checkbox", "id": "show_trust", "label": "Afficher les avis", "default": true },
    { "type": "checkbox", "id": "trust_below_mobile", "label": "Placer les avis sous le bouton (mobile)", "default": true },
    { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "Nombre d'étoiles pleines", "default": 4 },
