{%- comment -%}
  Section : Barre d'annonce avec icônes (avis, clients, récompenses...)
  - 100% personnalisable via l'éditeur de thème
  - Responsive : sur mobile, choix entre rotation automatique,
    défilement horizontal ou empilement
  Installation : Boutique en ligne > Thèmes > Modifier le code >
  Sections > Ajouter une nouvelle section > "barre-annonce" > coller ce code
{%- endcomment -%}

{%- style -%}
  #Annonce-{{ section.id }} {
    background: {{ section.settings.bg_color }};
    {%- if section.settings.show_border -%}
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    {%- endif -%}
    font-family: 'Epilogue', var(--font-body-family, sans-serif);
  }
  #Annonce-{{ section.id }} .annonce__wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.padding_y }}px 20px;
  }
  #Annonce-{{ section.id }} .annonce__items {
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.alignment }};
    gap: 16px {{ section.settings.gap }}px;
    flex-wrap: nowrap;
  }
  #Annonce-{{ section.id }} .annonce__item {
    display: flex;
    align-items: center;
    gap: 10px;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    text-decoration: none;
    white-space: nowrap;
    flex: none;
  }
  #Annonce-{{ section.id }} a.annonce__item:hover { text-decoration: underline; }
  #Annonce-{{ section.id }} .annonce__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    flex: none;
    display: inline-flex;
  }
  #Annonce-{{ section.id }} .annonce__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ section.settings.icon_color }};
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  #Annonce-{{ section.id }} .annonce__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #Annonce-{{ section.id }} .annonce__item strong { font-weight: 700; }

  /* ---------- MOBILE ---------- */
  @media screen and (max-width: 749px) {
    #Annonce-{{ section.id }} .annonce__wrapper {
      padding: {{ section.settings.padding_y_mobile }}px 16px;
    }
    #Annonce-{{ section.id }} .annonce__item {
      font-size: {{ section.settings.text_size_mobile }}px;
      justify-content: center;
    }

    {%- case section.settings.mobile_mode -%}

    {%- when 'rotate' -%}
    /* Rotation automatique : un message à la fois */
    #Annonce-{{ section.id }} .annonce__items {
      position: relative;
      justify-content: center;
      min-height: 1.6em;
    }
    #Annonce-{{ section.id }} .annonce__item {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity .5s ease;
      pointer-events: none;
    }
    #Annonce-{{ section.id }} .annonce__item.is-active {
      opacity: 1;
      pointer-events: auto;
    }

    {%- when 'scroll' -%}
    /* Défilement horizontal au doigt */
    #Annonce-{{ section.id }} .annonce__items {
      overflow-x: auto;
      justify-content: flex-start;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    #Annonce-{{ section.id }} .annonce__items::-webkit-scrollbar { display: none; }

    {%- else -%}
    /* Empilement vertical */
    #Annonce-{{ section.id }} .annonce__items {
      flex-direction: column;
      gap: 10px;
    }
    {%- endcase -%}
  }

  @media (prefers-reduced-motion: reduce) {
    #Annonce-{{ section.id }} .annonce__item { transition: none; }
  }
{%- endstyle -%}

{%- comment -%} Chargement de secours de la police Epilogue (ne fait rien si le thème la charge déjà) {%- endcomment -%}
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Epilogue:ital,wght@0,400;0,500;0,600;0,700&display=swap" rel="stylesheet">

<div id="Annonce-{{ section.id }}">
  <div class="annonce__wrapper">
    <div class="annonce__items" data-mobile-mode="{{ section.settings.mobile_mode }}" data-delay="{{ section.settings.rotate_delay | times: 1000 }}">
      {%- for block in section.blocks -%}
        {%- capture item_content -%}
          <span class="annonce__icon" aria-hidden="true">
            {%- if block.settings.icon_image != blank -%}
              {{ block.settings.icon_image | image_url: width: 60 | image_tag: loading: 'lazy', alt: '' }}
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24"><path d="M12 3l2.7 5.8 6.3.7-4.7 4.3 1.3 6.2-5.6-3.2-5.6 3.2 1.3-6.2L3 9.5l6.3-.7z"/></svg>
                {%- when 'heart' -%}
                  <svg viewBox="0 0 24 24"><path d="M12 20.5S4 15 4 9.5C4 6.5 6.3 4.5 8.8 4.5c1.5 0 2.6.8 3.2 1.8.6-1 1.7-1.8 3.2-1.8 2.5 0 4.8 2 4.8 5 0 5.5-8 11-8 11z"/></svg>
                {%- when 'medal' -%}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="9" r="5.5"/><path d="M9 13.5L7.5 21l4.5-2.6L16.5 21 15 13.5"/><path d="M12 6.7l.8 1.6 1.8.2-1.3 1.2.3 1.8-1.6-.9-1.6.9.3-1.8-1.3-1.2 1.8-.2z"/></svg>
                {%- when 'delivery' -%}
                  <svg viewBox="0 0 24 24"><rect x="2" y="6" width="13" height="10" rx="1"/><path d="M15 9h4l3 3v4h-7"/><circle cx="7" cy="18" r="1.8"/><circle cx="18" cy="18" r="1.8"/></svg>
                {%- when 'shield' -%}
                  <svg viewBox="0 0 24 24"><path d="M12 2.5l8 3v6c0 5-3.5 8.8-8 10.5-4.5-1.7-8-5.5-8-10.5v-6z"/><path d="M8.5 12l2.5 2.5L16 9.5"/></svg>
                {%- when 'moon' -%}
                  <svg viewBox="0 0 24 24"><path d="M20 14.5A8.5 8.5 0 019.5 4 8.5 8.5 0 1020 14.5z"/></svg>
                {%- when 'check' -%}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9"/><path d="M8 12.5l2.5 2.5L16 9.5"/></svg>
                {%- when 'gift' -%}
                  <svg viewBox="0 0 24 24"><rect x="4" y="9" width="16" height="11" rx="1"/><path d="M12 9v11M3.5 9h17M12 9s-1-4.5-3.7-4.5c-1.5 0-2.3 1-2.3 2.2C6 8.5 8 9 12 9zm0 0s1-4.5 3.7-4.5c1.5 0 2.3 1 2.3 2.2C18 8.5 16 9 12 9z"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </span>
          <span>{{ block.settings.text }}</span>
        {%- endcapture -%}

        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="annonce__item{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>{{ item_content }}</a>
        {%- else -%}
          <div class="annonce__item{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>{{ item_content }}</div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{%- if section.settings.mobile_mode == 'rotate' -%}
<script>
  (function () {
    var container = document.querySelector('#Annonce-{{ section.id }} .annonce__items');
    if (!container) return;
    var items = container.querySelectorAll('.annonce__item');
    if (items.length < 2) return;
    var delay = parseInt(container.dataset.delay, 10) || 4000;
    var index = 0;
    var mq = window.matchMedia('(max-width: 749px)');
    var timer = null;

    function next() {
      items[index].classList.remove('is-active');
      index = (index + 1) % items.length;
      items[index].classList.add('is-active');
    }
    function start() {
      if (timer || window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      timer = setInterval(next, delay);
    }
    function stop() {
      clearInterval(timer);
      timer = null;
    }
    function update() { mq.matches ? start() : stop(); }
    mq.addEventListener ? mq.addEventListener('change', update) : mq.addListener(update);
    update();
  })();
</script>
{%- endif -%}

{% schema %}
{
  "name": "Barre d'annonce icônes",
  "tag": "section",
  "class": "section-annonce-bar",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Mise en page" },
    { "type": "range", "id": "max_width", "min": 800, "max": 1800, "step": 20, "unit": "px", "label": "Largeur maximale", "default": 1400 },
    { "type": "select", "id": "alignment", "label": "Alignement (PC)", "default": "center",
      "options": [
        { "value": "flex-start", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "space-between", "label": "Réparti" },
        { "value": "flex-end", "label": "Droite" }
      ]
    },
    { "type": "range", "id": "gap", "min": 20, "max": 160, "step": 10, "unit": "px", "label": "Espace entre les éléments (PC)", "default": 90 },
    { "type": "range", "id": "padding_y", "min": 4, "max": 40, "step": 2, "unit": "px", "label": "Hauteur (PC)", "default": 14 },
    { "type": "range", "id": "padding_y_mobile", "min": 4, "max": 40, "step": 2, "unit": "px", "label": "Hauteur (mobile)", "default": 12 },
    { "type": "checkbox", "id": "show_border", "label": "Afficher les bordures haut/bas", "default": false },
    { "type": "color", "id": "border_color", "label": "Couleur des bordures", "default": "#E5E5E5" },

    { "type": "header", "content": "Couleurs & tailles" },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Texte", "default": "#1a1a1a" },
    { "type": "color", "id": "icon_color", "label": "Icônes", "default": "#1a1a1a" },
    { "type": "range", "id": "text_size", "min": 11, "max": 22, "step": 1, "unit": "px", "label": "Taille du texte (PC)", "default": 15 },
    { "type": "range", "id": "text_size_mobile", "min": 10, "max": 20, "step": 1, "unit": "px", "label": "Taille du texte (mobile)", "default": 13 },
    { "type": "range", "id": "icon_size", "min": 14, "max": 36, "step": 1, "unit": "px", "label": "Taille des icônes", "default": 20 },

    { "type": "header", "content": "Affichage mobile" },
    { "type": "select", "id": "mobile_mode", "label": "Mode d'affichage", "default": "rotate",
      "options": [
        { "value": "rotate", "label": "Rotation automatique (1 message à la fois)" },
        { "value": "scroll", "label": "Défilement horizontal au doigt" },
        { "value": "stack", "label": "Empilés les uns sous les autres" }
      ]
    },
    { "type": "range", "id": "rotate_delay", "min": 2, "max": 10, "step": 1, "unit": "s", "label": "Délai de rotation", "default": 4 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icône", "default": "star",
          "options": [
            { "value": "star", "label": "Étoile" },
            { "value": "heart", "label": "Cœur" },
            { "value": "medal", "label": "Médaille" },
            { "value": "delivery", "label": "Camion (livraison)" },
            { "value": "shield", "label": "Bouclier (garantie)" },
            { "value": "moon", "label": "Lune (sommeil)" },
            { "value": "check", "label": "Coche" },
            { "value": "gift", "label": "Cadeau" }
          ]
        },
        { "type": "image_picker", "id": "icon_image", "label": "Icône personnalisée (remplace celle du dessus)" },
        { "type": "text", "id": "text", "label": "Texte", "default": "4,5/5 sur plus de 33 000 avis" },
        { "type": "url", "id": "link", "label": "Lien (optionnel)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre d'annonce icônes",
      "blocks": [
        { "type": "item", "settings": { "icon": "star", "text": "4,5/5 sur plus de 33 000 avis" } },
        { "type": "item", "settings": { "icon": "heart", "text": "Plus de 1 500 000 clients satisfaits" } },
        { "type": "item", "settings": { "icon": "medal", "text": "Confort de sommeil primé" } }
      ]
    }
  ]
}
{% endschema %}
